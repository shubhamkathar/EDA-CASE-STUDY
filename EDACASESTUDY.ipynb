   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# ── Quick column overview ──────────────────────────────────────\n",
    "print(f\"Shape: {master_df.shape}\")\n",
    "print(f\"Total columns: {master_df.shape[1]}\")\n",
    "\n",
    "# ── 1. NULLS ───────────────────────────────────────────────────\n",
    "null_report = master_df.isnull().sum()\n",
    "null_report = null_report[null_report > 0].sort_values(ascending=False)\n",
    "print(\"\\n=== NULLS ===\")\n",
    "print(null_report)\n",
    "\n",
    "# ── 2. NEGATIVE VALUES (only numeric cols) ─────────────────────\n",
    "print(\"\\n=== NEGATIVE VALUES ===\")\n",
    "num_cols = master_df.select_dtypes(include=np.number).columns\n",
    "for col in num_cols:\n",
    "    neg = (master_df[col] < 0).sum()\n",
    "    if neg > 0:\n",
    "        print(f\"  {col}: {neg} negative values\")\n",
    "\n",
    "# ── 3. DUPLICATES ──────────────────────────────────────────────\n",
    "dups = master_df.duplicated().sum()\n",
    "print(f\"\\n=== DUPLICATE ROWS: {dups} ===\")\n",
    "\n",
    "# ── 4. CATEGORICAL GARBAGE ────────────────────────────────────\n",
    "print(\"\\n=== CATEGORICAL SUSPICIOUS VALUES ===\")\n",
    "cat_cols = master_df.select_dtypes(include='object').columns\n",
    "for col in cat_cols:\n",
    "    vc = master_df[col].value_counts()\n",
    "    # flag categories with very low count (likely garbage)\n",
    "    rare = vc[vc < 500]\n",
    "    if len(rare) > 0:\n",
    "        print(f\"  {col}: rare values → {rare.index.tolist()[:5]}\")\n",
    "\n",
    "# ── 5. DATE ISSUES ────────────────────────────────────────────\n",
    "print(\"\\n=== DATE ISSUES ===\")\n",
    "date_cols = [c for c in master_df.columns if 'date' in c.lower()]\n",
    "for col in date_cols:\n",
    "    parsed = pd.to_datetime(master_df[col], errors='coerce')\n",
    "    bad = parsed.isnull().sum()\n",
    "    future = (parsed > pd.Timestamp.today()).sum()\n",
    "    if bad > 0 or future > 0:\n",
    "        print(f\"  {col}: {bad} unparseable, {future} future dates\")\n",
    "\n",
    "# ── 6. IMPOSSIBLE RANGES ──────────────────────────────────────\n",
    "print(\"\\n=== OUTLIER / IMPOSSIBLE RANGES ===\")\n",
    "print(master_df[num_cols].describe().T[['min','max','mean']])"
   ]
  },
