    "before = master_df[top6].agg(['mean','std','max']).T\n",
    "print(before)\n",
    "\n",
    "# Step 3 - Winsorise at 1st and 99th percentile\n",
    "for col in top6:\n",
    "    p1  = master_df[col].quantile(0.01)\n",
    "    p99 = master_df[col].quantile(0.99)\n",
    "    master_df[col] = master_df[col].clip(lower=p1, upper=p99)\n",
    "\n",
    "# Step 4 - After stats\n",
    "print(\"\\n=== AFTER Winsorisation ===\")\n",
    "after = master_df[top6].agg(['mean','std','max']).T\n",
