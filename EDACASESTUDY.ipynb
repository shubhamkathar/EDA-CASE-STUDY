    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "df1 = pd.read_csv(r\"C:\\Users\\SHUBHAM\\Downloads\\monthly_emi_track.csv\")\n",
    "df2 = pd.read_csv(r\"C:\\Users\\SHUBHAM\\Downloads\\branch_region_economy.csv\")\n",
    "df3 = pd.read_csv(r\"C:\\Users\\SHUBHAM\\Downloads\\collateral_assets.csv\")\n",
    "df4 = pd.read_csv(r\"C:\\Users\\SHUBHAM\\Downloads\\credit_card_behavior.csv\")\n",
    "df5 = pd.read_csv(r\"C:\\Users\\SHUBHAM\\Downloads\\customer_bureau.csv\")\n",
    "df6 = pd.read_csv(r\"C:\\Users\\SHUBHAM\\Downloads\\loans_master.csv\")\n",
    "df7 = pd.read_csv(r\"C:\\Users\\SHUBHAM\\Downloads\\loan_enquiry_bureau.csv\")\n",
    "df8 = pd.read_csv(r\"C:\\Users\\SHUBHAM\\Downloads\\loan_performance.csv\")\n",
    "df9 = pd.read_csv(r\"C:\\Users\\SHUBHAM\\Downloads\\payment_history.csv\")\n",
    "\n",
    "all_dfs = [df1, df2, df3, df4, df5, df6, df7, df8, df9]\n",
    "\n"
   ]
  },
