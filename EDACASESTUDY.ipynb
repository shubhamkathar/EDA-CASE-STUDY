   "source": [
    "# 1. df6 (loans_master.csv)\n",
    "master_df = df6.copy()\n",
    "print(f\"Base row count (loans_master): {len(master_df)}\")\n",
    "\n",
    "# \n",
    "orphans_found = {}\n",
    "\n",
    "# 2. File 1 (monthly_emi_track)\n",
    "orphans_found[\"monthly_emi_track\"] = len(df1[~df1[\"loan_id\"].isin(df6[\"loan_id\"])])\n",
    "master_df = pd.merge(master_df, df1, on=\"loan_id\", how=\"left\")\n",
    "print(f\"File 1 (EMI Track): {len(master_df)}\")\n",
    "\n",
    "# 3. File 2 (branch_region_economy) ko merge karo aur orphan gino\n",
    "orphans_found[\"branch_region_economy\"] = len(\n",
    "    df2[~df2[\"loan_id\"].isin(df6[\"loan_id\"])]\n",
    ")\n",
    "master_df = pd.merge(master_df, df2, on=\"loan_id\", how=\"left\")\n",
    "print(f\"File 2 (Branch) merge ke baad total rows: {len(master_df)}\")\n",
    "\n",
    "# 4. File 3 (collateral_assets) ko merge karo aur orphan gino\n",
    "orphans_found[\"collateral_assets\"] = len(df3[~df3[\"loan_id\"].isin(df6[\"loan_id\"])])\n",
    "master_df = pd.merge(master_df, df3, on=\"loan_id\", how=\"left\")\n",
    "print(f\"File 3 (Collateral) merge ke baad total rows: {len(master_df)}\")\n",
    "\n",
    "# 5. File 4 (credit_card_behavior) ko merge karo aur orphan gino\n",
    "orphans_found[\"credit_card_behavior\"] = len(\n",
    "    df4[~df4[\"loan_id\"].isin(df6[\"loan_id\"])]\n",
    ")\n",
    "master_df = pd.merge(master_df, df4, on=\"loan_id\", how=\"left\")\n",
    "print(f\"File 4 (Credit Card) merge ke baad total rows: {len(master_df)}\")\n",
    "\n",
    "# 6. File 5 (customer_bureau) ko merge karo aur orphan gino\n",
    "orphans_found[\"customer_bureau\"] = len(df5[~df5[\"loan_id\"].isin(df6[\"loan_id\"])])\n",
    "master_df = pd.merge(master_df, df5, on=\"loan_id\", how=\"left\")\n",
    "print(f\"File 5 (Bureau) merge ke baad total rows: {len(master_df)}\")\n",
    "\n",
    "# Note: df6 hamara base hai, toh use khud se merge nahi karna hai!\n",
    "\n",
    "# 7. File 7 (loan_enquiry_bureau) ko merge karo aur orphan gino\n",
    "orphans_found[\"loan_enquiry_bureau\"] = len(\n",
    "    df7[~df7[\"loan_id\"].isin(df6[\"loan_id\"])]\n",
    ")\n",
    "master_df = pd.merge(master_df, df7, on=\"loan_id\", how=\"left\")\n",
    "print(f\"File 7 (Enquiry) merge ke baad total rows: {len(master_df)}\")\n",
    "\n",
    "# 8. File 8 (loan_performance) ko merge karo aur orphan gino\n",
    "orphans_found[\"loan_performance\"] = len(df8[~df8[\"loan_id\"].isin(df6[\"loan_id\"])])\n",
    "master_df = pd.merge(master_df, df8, on=\"loan_id\", how=\"left\")\n",
    "print(f\"File 8 (Performance) merge ke baad total rows: {len(master_df)}\")\n",
    "\n",
    "# 9. File 9 (payment_history) ko merge karo aur orphan gino\n",
    "orphans_found[\"payment_history\"] = len(df9[~df9[\"loan_id\"].isin(df6[\"loan_id\"])])\n",
    "master_df = pd.merge(master_df, df9, on=\"loan_id\", how=\"left\")\n",
    "print(f\"Final master_df total rows after all merges: {len(master_df)}\\n\")\n",
    "\n",
    "# --- Final Orphan Records Report ---\n",
    "print(\"=================== ORPHAN RECORDS REPORT ===================\")\n",
    "for file_name, count in orphans_found.items():\n",
    "    print(f\"    * {file_name}: {count} orphans found\")\n",
    "print(\"=============================================================\")\n"
   ]
