   "source": [
    "'''\n",
    "Qd) Compute a Pearson correlation matrix for the top 20 numeric features and display it as an annotated heatmap.\n",
    "Identify any pair with |r| > 0.75 and\n",
    "explain why high correlation between predictors is problematic in OLS regression'''\n",
    "\n",
    "'''If two columns are highly related (like loan_amnt and installment) \n",
    "— they are giving same information twice. Model gets confused. \n",
    "This is called Multicollinearity.'''\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# use only 50,000 rows sample\n",
    "sample = master_df[cols].sample(50000, random_state=42)\n",
    "\n",
    "# correlation matrix\n",
    "corr = sample.corr()\n",
    "\n",
    "# heatmap\n",
    "plt.figure(figsize=(14, 10))\n",
    "plt.imshow(corr, cmap='coolwarm', aspect='auto')\n",
    "plt.colorbar()\n",
    "plt.xticks(range(len(cols)), cols, rotation=90)\n",
    "plt.yticks(range(len(cols)), cols)\n",
    "plt.title('Pearson Correlation Heatmap - Top 20 Features')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# find pairs with correlation > 0.75\n",
    "print(\"=== HIGH CORRELATION PAIRS (|r| > 0.75) ===\")\n",
    "for i in range(len(corr)):\n",
    "    for j in range(i+1, len(corr)):\n",
    "        if abs(corr.iloc[i,j]) > 0.75:\n",
    "            print(f\"{cols[i]:25s} vs {cols[j]:25s} : {corr.iloc[i,j]:.2f}\")"
   ]
